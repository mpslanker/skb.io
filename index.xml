&lt;span style="color:#8f5902;font-style:italic">#TcpRcvBufPoll yes&lt;/span>
&lt;span style="color:#8f5902;font-style:italic"># disable hpn performance boosts&lt;/span>
&lt;span style="color:#8f5902;font-style:italic">#HPNDisabled no&lt;/span>
&lt;span style="color:#8f5902;font-style:italic"># buffer size for hpn to non-hpn connections&lt;/span>
&lt;span style="color:#8f5902;font-style:italic">#HPNBufferSize 2048&lt;/span>
&lt;span style="color:#8f5902;font-style:italic"># allow the use of the none cipher&lt;/span>
&lt;span style="color:#8f5902;font-style:italic">#NoneEnabled no&lt;/span>
&lt;span style="color:#8f5902;font-style:italic"># Example of overriding settings on a per-user basis&lt;/span>
&lt;span style="color:#8f5902;font-style:italic">#Match User anoncvs&lt;/span>
&lt;span style="color:#8f5902;font-style:italic"># X11Forwarding no&lt;/span>
&lt;span style="color:#8f5902;font-style:italic"># AllowTcpForwarding no&lt;/span>
&lt;span style="color:#8f5902;font-style:italic"># PermitTTY no&lt;/span>
&lt;span style="color:#8f5902;font-style:italic"># ForceCommand cvs server&lt;/span>
Match User root
AllowTcpForwarding yes
Match User admin
AllowTcpForwarding yes
Match User anonymous
AllowTcpForwarding no
GatewayPorts no
